/**
 * AGRO FORTE — script.js
 * Vanilla JS modular · sem dependências externas
 * ──────────────────────────────────────────────
 * Módulos:
 *   initFont        → controle de tamanho de fonte (A+/A/A-)
 *   initTheme       → modos claro / escuro / alto contraste
 *   initSpeech      → leitura em voz alta (Speech Synthesis API)
 *   initNav         → header, menu mobile, link ativo ao rolar
 *   initReveal      → animações de entrada por scroll
 *   initBenBars     → barras animadas dos benefícios
 *   initDadoCounters→ contadores animados das estatísticas
 *   initTimeline    → animação progressiva da linha do tempo
 *   initTechCards   → flip dos cards de tecnologia (teclado)
 *   initQuiz        → quiz interativo completo
 *   initImpact      → contadores de impacto em tempo real
 */

/* ════════════════════════════════════════════════════
   DADOS DO QUIZ
════════════════════════════════════════════════════ */
const QUIZ = [
  {
    q: "Qual prática agrícola reduz a erosão do solo e preserva sua umidade natural?",
    opts: [
