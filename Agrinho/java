    ],
    ok: 1,
    fb: {
      sim: "Correto! O plantio direto mantém a cobertura vegetal no solo, reduzindo a erosão em até 72% e preservando a umidade para as raízes.",
      nao: "Incorreto. O plantio direto é a resposta correta — mantém palha e resíduos vegetais que protegem o solo da erosão e do ressecamento."
    }
  },
  {
    q: "Qual sistema de irrigação é mais eficiente na economia de água?",
    opts: [
      "Aspersão convencional de área total",
      "Inundação por sulcos entre fileiras",
      "Gotejamento localizado com sensores de umidade",
      "Pivô central sem controle automatizado"
    ],
    ok: 2,
    fb: {
      sim: "Correto! O gotejamento com sensores entrega água diretamente na zona radicular, economizando até 85% em comparação à aspersão convencional.",
      nao: "Incorreto. O gotejamento com sensores é a alternativa correta — aplica precisamente a quantidade necessária, direto na raiz da planta."
    }
  },
  {
    q: "Qual porcentagem da água doce mundial é consumida pela agricultura?",
    opts: ["30%", "50%", "70%", "90%"],
    ok: 2,
    fb: {
      sim: "Correto! Aproximadamente 70% de toda a água doce consumida no mundo é destinada à irrigação e às atividades agropecuárias.",
      nao: "Incorreto. A resposta correta é 70%. A agricultura é, de longe, a maior consumidora de água doce do planeta."
    }
  },
  {
    q: "O que é o sistema de Integração Lavoura-Pecuária-Floresta (iLPF)?",
    opts: [
      "Técnica de desmatamento estratégico para ampliar pastagens",
